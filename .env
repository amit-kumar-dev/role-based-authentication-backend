MONGO_URI=mongodb://localhost:27017/mediaprodb
JWT_SECRET=ff52abc1a0194ff3422e014e490b095f64b77ad554bd41df846ca8f31bd8c15e
# for minio upload as cloudnary
# MinIO credentials
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin123



# MinIO bucket
MINIO_BUCKET=images
MINIO_USE_SSL=false
MINIO_REGION=us-east-1

# for local storage
# The base URL used to build absolute URLs (optional; relative URLs if not set)
VITE_API_BASE_URL=http://localhost:3000

# Where to store files on disk (absolute or relative to project root)
# Since you want src/images:
UPLOAD_DIR=src/images

# Public route where files are served (match app.use mount path)
PUBLIC_MOUNT_PATH=/images

# Max upload size in bytes (10 MB default)
MAX_FILE_SIZE=10485760

# Allowed mime types (comma separated)

# Allowed mime types (images + pdf + audio + video)
ALLOWED_MIME=image/jpeg,image/png,image/webp,image/gif,application/pdf,audio/mpeg,audio/wav,audio/mp3,video/mp4,video/mkv

# Express port
PORT=3000
